<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    
    <IsPackable>true</IsPackable> 
    
    
    
    <PackageId>PurelySharp.Attributes</PackageId>
    <Version>0.0.4</Version> 
    <Authors>Alex Yorke</Authors>
    <Description>Contains PurelySharp purity attributes including EnforcePureAttribute, PureAttribute, PureExternalAttribute, ImpureAttribute, and AllowSynchronizationAttribute for analyzer-checked C# projects.</Description>
    <PackageTags>PurelySharp;Attributes;Roslyn;Analyzer;Purity</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <Title>PurelySharp.Attributes</Title>
    <PackageProjectUrl>https://github.com/alexyorke/PurelySharp</PackageProjectUrl>
    <RepositoryUrl>https://github.com/alexyorke/PurelySharp</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageReleaseNotes>Add PureExternalAttribute and ImpureAttribute boundary markers alongside EnforcePureAttribute, PureAttribute, and AllowSynchronizationAttribute.</PackageReleaseNotes>
    <GeneratePackageOnBuild>True</GeneratePackageOnBuild> 
    

  </PropertyGroup>

  <ItemGroup>
    <None Include="..\README.md">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
  </ItemGroup>

</Project> 
